@page "/empleados"
@using GestionObras.Core.Entities
@using GestionObras.Infrastructure.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrador,JefeObra,OficinaTecnica")]
@rendermode InteractiveServer
@inject GestionObrasDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<UsuarioObra> UserManager
@inject GestionObras.Web.Services.ExportPdfService ExportPdf
@inject GestionObras.Web.Services.ExportExcelService ExportExcel
@inject IJSRuntime JS

<PageTitle>Empleados - Gestión Obras</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-people"></i> Gestión Jerárquica de Empleados
        </h1>
        <div class="d-flex gap-2">
            <div class="btn-group">
                <button class="btn btn-outline-danger" @onclick="ExportarPdf" title="Exportar a PDF">
                    <i class="bi bi-file-earmark-pdf"></i> PDF
                </button>
                <button class="btn btn-outline-success" @onclick="ExportarExcel" title="Exportar a Excel">
                    <i class="bi bi-file-earmark-spreadsheet"></i> Excel
                </button>
            </div>
            <button class="btn btn-primary" @onclick="AbrirModalNuevo">
                <i class="bi bi-plus-circle"></i> Nuevo Empleado
            </button>
        </div>
    </div>

    <div class="alert alert-primary">
        <i class="bi bi-diagram-3"></i>
        <strong>Vista jerárquica:</strong> @descripcionJerarquiaActual
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="🔍 Buscar por nombre..."
                           @bind="filtroNombre" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filtroEstado">
                        <option value="">Todos los estados</option>
                        <option value="true">Activos</option>
                        <option value="false">Inactivos</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-outline-secondary w-100" @onclick="LimpiarFiltros">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de empleados -->
    <div class="card">
        <div class="card-body">
            @if (cargando)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted">Cargando empleados...</p>
                </div>
            }
            else if (!empleadosFiltrados.Any())
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle"></i> No se encontraron empleados
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>DNI</th>
                                <th>Email</th>
                                <th>Teléfono</th>
                                <th>Departamento</th>
                                <th>Cargo</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var empleado in empleadosFiltrados)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-2">
                                                @ObtenerIniciales(empleado)
                                            </div>
                                            <strong>@empleado.Nombre @empleado.Apellidos</strong>
                                        </div>
                                    </td>
                                    <td>@empleado.DNI</td>
                                    <td>@empleado.Email</td>
                                    <td>@empleado.Telefono</td>
                                    <td>
                                        <span class="badge bg-info">@empleado.Departamento</span>
                                    </td>
                                    <td>@empleado.Cargo</td>
                                    <td>
                                        @if (empleado.Activo)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group" role="group">
                                            <button class="btn btn-sm btn-outline-primary" 
                                                    @onclick="() => AbrirModalEditar(empleado)"
                                                    title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" 
                                                    @onclick="() => ConfirmarEliminar(empleado)"
                                                    title="Eliminar">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal para crear/editar empleado -->
@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(empleadoSeleccionado.Id == 0 ? "Nuevo Empleado" : "Editar Empleado")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nombre *</label>
                            <input class="form-control" @bind="empleadoSeleccionado.Nombre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Apellidos *</label>
                            <input class="form-control" @bind="empleadoSeleccionado.Apellidos" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">DNI *</label>
                            <input class="form-control" @bind="empleadoSeleccionado.DNI" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email *</label>
                            <input type="email" class="form-control" @bind="empleadoSeleccionado.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Teléfono *</label>
                            <input class="form-control" @bind="empleadoSeleccionado.Telefono" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fecha de Contratación *</label>
                            <input type="date" class="form-control" @bind="empleadoSeleccionado.FechaContratacion" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Departamento *</label>
                            <input class="form-control" @bind="empleadoSeleccionado.Departamento" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Cargo *</label>
                            <input class="form-control" @bind="empleadoSeleccionado.Cargo" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Dirección</label>
                            <input class="form-control" @bind="empleadoSeleccionado.Direccion" />
                        </div>
                        <div class="col-md-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="empleadoSeleccionado.Activo" />
                                <label class="form-check-label">Empleado activo</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="GuardarEmpleado">
                        <i class="bi bi-save2"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación de eliminación -->
@if (mostrarModalEliminar)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalEliminar"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro de que desea eliminar al empleado?</p>
                    <p class="fw-bold">@empleadoAEliminar?.Nombre @empleadoAEliminar?.Apellidos</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModalEliminar">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarEmpleado">
                        <i class="bi bi-trash3-fill"></i> Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Empleado> empleados = new();
    private bool cargando = true;
    private bool mostrarModal = false;
    private bool mostrarModalEliminar = false;
    private Empleado empleadoSeleccionado = new();
    private Empleado? empleadoAEliminar;
    private string? errorMensaje;

    // Mapeo de Id secuencial del Empleado al Id real de UsuarioObra
    private Dictionary<int, string> empleadoUsuarioMap = new();

    private string filtroNombre = "";
    private string filtroEstado = "";
    private HashSet<string> rolesUsuarioActual = new();
    private string descripcionJerarquiaActual = "Cargando jerarquía...";

    private IEnumerable<Empleado> empleadosFiltrados => empleados
        .Where(e => string.IsNullOrEmpty(filtroNombre) || 
                   $"{e.Nombre} {e.Apellidos}".Contains(filtroNombre, StringComparison.OrdinalIgnoreCase))
        .Where(e => string.IsNullOrEmpty(filtroEstado) || e.Activo.ToString().Equals(filtroEstado, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpleados();
    }

    private async Task CargarEmpleados()
    {
        cargando = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;
        var usuarioActual = await UserManager.GetUserAsync(principal);
        rolesUsuarioActual = usuarioActual != null
            ? (await UserManager.GetRolesAsync(usuarioActual)).ToHashSet()
            : new HashSet<string>();

        descripcionJerarquiaActual = ObtenerDescripcionJerarquia();

        var usuarios = await DbContext.Users
            .OrderBy(u => u.NombreCompleto)
            .ToListAsync();

        var lista = new List<Empleado>();
        empleadoUsuarioMap = new();
        var idSecuencial = 1;

        foreach (var usuario in usuarios)
        {
            var rolesEmpleado = await UserManager.GetRolesAsync(usuario);
            if (!PuedeVerUsuarioPorJerarquia(rolesEmpleado))
            {
                continue;
            }

            var (nombre, apellidos) = SepararNombreCompleto(usuario.NombreCompleto);
            var rolPrincipal = rolesEmpleado.FirstOrDefault() ?? "Sin rol";

            var empId = idSecuencial++;
            empleadoUsuarioMap[empId] = usuario.Id;

            lista.Add(new Empleado
            {
                Id = empId,
                Nombre = nombre,
                Apellidos = apellidos,
                DNI = usuario.DNI,
                Email = usuario.Email ?? string.Empty,
                Telefono = usuario.TelefonoMovil ?? usuario.PhoneNumber ?? string.Empty,
                Departamento = rolPrincipal,
                Cargo = string.IsNullOrWhiteSpace(usuario.Cargo) ? rolPrincipal : usuario.Cargo,
                FechaContratacion = usuario.FechaCreacion,
                Direccion = null,
                Activo = usuario.Activo
            });
        }

        empleados = lista;

        cargando = false;
    }

    private void AbrirModalNuevo()
    {
        empleadoSeleccionado = new Empleado 
        { 
            FechaContratacion = DateTime.Today,
            Activo = true
        };
        errorMensaje = null;
        mostrarModal = true;
    }

    private void AbrirModalEditar(Empleado empleado)
    {
        empleadoSeleccionado = new Empleado
        {
            Id = empleado.Id,
            Nombre = empleado.Nombre,
            Apellidos = empleado.Apellidos,
            DNI = empleado.DNI,
            Email = empleado.Email,
            Telefono = empleado.Telefono,
            FechaContratacion = empleado.FechaContratacion,
            Departamento = empleado.Departamento,
            Cargo = empleado.Cargo,
            Direccion = empleado.Direccion,
            Activo = empleado.Activo
        };
        errorMensaje = null;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        empleadoSeleccionado = new();
        errorMensaje = null;
    }

    private async Task GuardarEmpleado()
    {
        try
        {
            if (empleadoSeleccionado.Id == 0)
            {
                // Crear nuevo UsuarioObra
                var nuevoUsuario = new UsuarioObra
                {
                    UserName = empleadoSeleccionado.Email,
                    Email = empleadoSeleccionado.Email,
                    NombreCompleto = $"{empleadoSeleccionado.Nombre} {empleadoSeleccionado.Apellidos}",
                    DNI = empleadoSeleccionado.DNI,
                    TelefonoMovil = empleadoSeleccionado.Telefono,
                    Cargo = empleadoSeleccionado.Cargo,
                    Activo = empleadoSeleccionado.Activo,
                    FechaCreacion = empleadoSeleccionado.FechaContratacion
                };

                var result = await UserManager.CreateAsync(nuevoUsuario, "Temporal1");
                if (!result.Succeeded)
                {
                    errorMensaje = string.Join(", ", result.Errors.Select(e => e.Description));
                    return;
                }

                // Asignar rol si se especificó un departamento válido
                if (!string.IsNullOrEmpty(empleadoSeleccionado.Departamento))
                {
                    await UserManager.AddToRoleAsync(nuevoUsuario, empleadoSeleccionado.Departamento);
                }
            }
            else
            {
                // Editar UsuarioObra existente
                if (empleadoUsuarioMap.TryGetValue(empleadoSeleccionado.Id, out var usuarioId))
                {
                    var usuario = await UserManager.FindByIdAsync(usuarioId);
                    if (usuario != null)
                    {
                        usuario.NombreCompleto = $"{empleadoSeleccionado.Nombre} {empleadoSeleccionado.Apellidos}";
                        usuario.DNI = empleadoSeleccionado.DNI;
                        usuario.Email = empleadoSeleccionado.Email;
                        usuario.UserName = empleadoSeleccionado.Email;
                        usuario.TelefonoMovil = empleadoSeleccionado.Telefono;
                        usuario.Cargo = empleadoSeleccionado.Cargo;
                        usuario.Activo = empleadoSeleccionado.Activo;

                        var result = await UserManager.UpdateAsync(usuario);
                        if (!result.Succeeded)
                        {
                            errorMensaje = string.Join(", ", result.Errors.Select(e => e.Description));
                            return;
                        }
                    }
                }
            }

            await CargarEmpleados();
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error al guardar: {ex.Message}";
            Console.WriteLine($"Error al guardar empleado: {ex.Message}");
            return;
        }

        CerrarModal();
    }

    private void ConfirmarEliminar(Empleado empleado)
    {
        empleadoAEliminar = empleado;
        mostrarModalEliminar = true;
    }

    private void CerrarModalEliminar()
    {
        mostrarModalEliminar = false;
        empleadoAEliminar = null;
    }

    private async Task EliminarEmpleado()
    {
        if (empleadoAEliminar != null && empleadoUsuarioMap.TryGetValue(empleadoAEliminar.Id, out var usuarioId))
        {
            try
            {
                var usuario = await UserManager.FindByIdAsync(usuarioId);
                if (usuario != null)
                {
                    // Desactivar en lugar de eliminar (soft delete)
                    usuario.Activo = false;
                    await UserManager.UpdateAsync(usuario);
                    await CargarEmpleados();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al desactivar empleado: {ex.Message}");
            }
        }
        CerrarModalEliminar();
    }

    private void LimpiarFiltros()
    {
        filtroNombre = "";
        filtroEstado = "";
    }

    private bool PuedeVerUsuarioPorJerarquia(IList<string> rolesEmpleado)
    {
        if (rolesUsuarioActual.Contains("Administrador"))
        {
            return true;
        }

        // Jerarquía horizontal: JefeObra y OficinaTecnica son pares.
        // Ambos gestionan su propio escalón inferior especializado.
        if (rolesUsuarioActual.Contains("JefeObra") || rolesUsuarioActual.Contains("OficinaTecnica"))
        {
            if (rolesUsuarioActual.Contains("JefeObra"))
            {
                return rolesEmpleado.Contains("OperarioObra") || rolesEmpleado.Contains("Operario");
            }

            if (rolesUsuarioActual.Contains("OficinaTecnica"))
            {
                return rolesEmpleado.Contains("OperarioOficinaT") || rolesEmpleado.Contains("Operario");
            }
        }

        return false;
    }

    private string ObtenerDescripcionJerarquia()
    {
        if (rolesUsuarioActual.Contains("Administrador"))
        {
            return "Como Administrador ves todos los escalones.";
        }

        if (rolesUsuarioActual.Contains("JefeObra"))
        {
            return "Como Jefe de Obra ves y gestionas Operario-Obra (Oficina Técnica es horizontal, interoperable por tareas conjuntas).";
        }

        if (rolesUsuarioActual.Contains("OficinaTecnica"))
        {
            return "Como Oficina Técnica ves y gestionas Operario-OficinaT (Jefe de Obra es horizontal, interoperable por tareas conjuntas).";
        }

        return "Tu rol no tiene un escalón inferior configurable en este módulo.";
    }

    private static (string nombre, string apellidos) SepararNombreCompleto(string? nombreCompleto)
    {
        if (string.IsNullOrWhiteSpace(nombreCompleto))
        {
            return ("Sin", "Nombre");
        }

        var partes = nombreCompleto.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length == 1)
        {
            return (partes[0], string.Empty);
        }

        return (partes[0], string.Join(' ', partes.Skip(1)));
    }

    private static string ObtenerIniciales(Empleado empleado)
    {
        var inicialNombre = string.IsNullOrWhiteSpace(empleado.Nombre) ? "?" : empleado.Nombre.Substring(0, 1).ToUpper();
        var inicialApellido = string.IsNullOrWhiteSpace(empleado.Apellidos) ? "?" : empleado.Apellidos.Substring(0, 1).ToUpper();
        return $"{inicialNombre}{inicialApellido}";
    }

    private async Task ExportarPdf()
    {
        var datos = empleadosFiltrados.ToList();
        var bytes = ExportPdf.GenerarInformeEmpleados(datos);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("descargarArchivo", $"Empleados_{DateTime.Now:yyyyMMdd}.pdf", "application/pdf", base64);
    }

    private async Task ExportarExcel()
    {
        var datos = empleadosFiltrados.ToList();
        var bytes = ExportExcel.GenerarExcelEmpleados(datos);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("descargarArchivo", $"Empleados_{DateTime.Now:yyyyMMdd}.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
    }
}
