@page "/jefe-obra/horarios"
@attribute [Authorize(Roles = "JefeObra,OficinaTecnica,Administrador")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using GestionObras.Core.Entities
@using GestionObras.Infrastructure.Data
@using GestionObras.Infrastructure.Repositories
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject GestionObrasDbContext DbContext
@inject IFichajeRepository FichajeRepo
@inject UserManager<UsuarioObra> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Horarios de mi equipo - Gestión de Obras</PageTitle>

<style>
    .cal-grid {
        display: grid;
        grid-template-columns: 220px repeat(7, 1fr);
        gap: 1px;
        background: #dee2e6;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .cal-hdr {
        background: #2c3e50;
        color: white;
        padding: 14px 8px;
        font-weight: 600;
        text-align: center;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .cal-hdr.corner { background: #1a252f; }
    .cal-hdr.hoy { background: #1b5e20; }
    .cal-name {
        background: #f8f9fa;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-right: 3px solid #2c3e50;
        min-height: 76px;
    }
    .cal-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white; display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
    }
    .cal-name-info { display: flex; flex-direction: column; }
    .cal-name-info strong { font-size: 0.85rem; color: #2c3e50; }
    .cal-name-info small { font-size: 0.72rem; color: #6c757d; }
    .cal-cell {
        background: white; padding: 5px; min-height: 76px;
        display: flex; flex-direction: column; gap: 3px;
    }
    .cal-cell.hoy-col { background: #e8f5e9; }
    .turno-pill {
        border-radius: 8px; padding: 4px 8px; font-size: 0.72rem;
        font-weight: 600; display: flex; align-items: center; gap: 4px;
        line-height: 1.3;
    }
    .t-man { background: #fff3cd; color: #856404; border-left: 3px solid #ffc107; }
    .t-tar { background: #cfe2ff; color: #084298; border-left: 3px solid #0d6efd; }
    .t-noc { background: #d3d3d9; color: #1e1e2f; border-left: 3px solid #343a40; }
    .t-par { background: #e2d9f3; color: #432874; border-left: 3px solid #6f42c1; }
    .legend-bar { display: flex; gap: 18px; flex-wrap: wrap; align-items: center; }
    .legend-dot { width: 14px; height: 14px; border-radius: 4px; }
    .legend-item { display: flex; align-items: center; gap: 5px; font-size: 0.82rem; }
</style>

@if (cargando)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
    </div>
}
else
{
    <div class="container-fluid px-4 py-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="text-primary">📅 Horarios de mi equipo</h1>
                <p class="text-muted mb-0">Consulta los turnos semanales de los operarios en tus proyectos</p>
            </div>
            <span class="badge bg-info fs-6">👁️ Solo lectura</span>
        </div>

        <!-- Filtros + Leyenda -->
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Proyecto</label>
                        <select class="form-select" @bind="filtroProyectoId" @bind:after="CargarHorarios">
                            <option value="">Todos mis proyectos</option>
                            @foreach (var p in misProyectos)
                            {
                                <option value="@p.Id">@p.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Operario</label>
                        <select class="form-select" @bind="filtroUsuarioId" @bind:after="CargarHorarios">
                            <option value="">Todos</option>
                            @foreach (var u in operariosDisponibles)
                            {
                                <option value="@u.Id">@u.NombreCompleto</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="legend-bar ms-auto">
                            <div class="legend-item"><div class="legend-dot" style="background:#ffc107;"></div> Mañana</div>
                            <div class="legend-item"><div class="legend-dot" style="background:#0d6efd;"></div> Tarde</div>
                            <div class="legend-item"><div class="legend-dot" style="background:#343a40;"></div> Noche</div>
                            <div class="legend-item"><div class="legend-dot" style="background:#6f42c1;"></div> Partido</div>
                            <span class="badge bg-secondary ms-2">@horarios.Count turnos · @trabConHorario.Count personas</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CALENDARIO SEMANAL (Solo lectura) -->
        @if (!trabConHorario.Any())
        {
            <div class="card shadow-sm border-0">
                <div class="card-body text-center p-5">
                    <div class="display-1 mb-3">📅</div>
                    <h4 class="text-muted">No hay horarios asignados para tu equipo</h4>
                    <p class="text-muted">Contacta con RRHH para configurar los turnos</p>
                </div>
            </div>
        }
        else
        {
            <div class="cal-grid">
                <div class="cal-hdr corner">👤 Operario</div>
                @foreach (DiaSemana dia in Enum.GetValues<DiaSemana>())
                {
                    <div class="cal-hdr @(EsHoy(dia) ? "hoy" : "")">
                        @DiaCorto(dia)
                        @if (EsHoy(dia)) { <br/><span style="font-weight:400;opacity:0.8;font-size:0.7rem;">HOY</span> }
                    </div>
                }

                @foreach (var t in trabConHorario)
                {
                    var hSem = HorasSemana(t.Id);
                    <div class="cal-name">
                        <div class="cal-avatar">@Iniciales(t.NombreCompleto)</div>
                        <div class="cal-name-info">
                            <strong>@t.NombreCompleto</strong>
                            <small>@hSem.ToString("F0") h / semana</small>
                        </div>
                    </div>

                    @foreach (DiaSemana dia in Enum.GetValues<DiaSemana>())
                    {
                        var turnos = TurnosDia(t.Id, dia);
                        <div class="cal-cell @(EsHoy(dia) ? "hoy-col" : "")">
                            @foreach (var h in turnos)
                            {
                                <div class="turno-pill @TurnoClass(h.TipoTurno)">
                                    @TurnoIcon(h.TipoTurno) @h.HoraEntrada.ToString("HH:mm")-@h.HoraSalida.ToString("HH:mm")
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            @if (horarios.Any(h => h.Proyecto != null))
            {
                <div class="card shadow-sm border-0 mt-4">
                    <div class="card-header bg-white fw-semibold">📊 Resumen por proyecto</div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th>Proyecto</th><th>Trabajadores</th><th>Turnos</th><th>Horas/sem</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var g in horarios.Where(h => h.Proyecto != null).GroupBy(h => h.Proyecto!.Nombre))
                                {
                                    <tr>
                                        <td><strong>@g.Key</strong></td>
                                        <td>@g.Select(h => h.UsuarioId).Distinct().Count()</td>
                                        <td>@g.Count()</td>
                                        <td>@g.Sum(h => h.HorasPrevistas).ToString("F0") h</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private bool cargando = true;
    private UsuarioObra? usuarioActual;
    private List<Proyecto> misProyectos = new();
    private List<UsuarioObra> operariosDisponibles = new();
    private List<HorarioAsignado> horarios = new();
    private List<UsuarioObra> trabConHorario = new();

    private string filtroProyectoId = "";
    private string filtroUsuarioId = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            usuarioActual = await UserManager.GetUserAsync(authState.User);
            if (usuarioActual != null)
            {
                await CargarDatosIniciales();
                await CargarHorarios();
            }
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarDatosIniciales()
    {
        misProyectos = await DbContext.Proyectos
            .Where(p => p.ResponsableId == usuarioActual!.Id)
            .OrderBy(p => p.Nombre).ToListAsync();
        var operarioRoles = new[] { "Operario", "OperarioObra", "OperarioOficinaT" };
        var todosUsuarios = await DbContext.Users.Where(u => u.Activo).OrderBy(u => u.NombreCompleto).ToListAsync();
        operariosDisponibles = new List<UsuarioObra>();
        foreach (var u in todosUsuarios)
        {
            var roles = await UserManager.GetRolesAsync(u);
            if (roles.Any(r => operarioRoles.Contains(r)))
                operariosDisponibles.Add(u);
        }
    }

    private async Task CargarHorarios()
    {
        var proyectoIds = misProyectos.Select(p => p.Id).ToList();
        IQueryable<HorarioAsignado> q = DbContext.HorariosAsignados
            .Include(h => h.Usuario).Include(h => h.Proyecto)
            .Where(h => h.Activo && h.ProyectoId != null && proyectoIds.Contains(h.ProyectoId.Value));
        if (!string.IsNullOrEmpty(filtroProyectoId) && int.TryParse(filtroProyectoId, out int pid))
            q = q.Where(h => h.ProyectoId == pid);
        if (!string.IsNullOrEmpty(filtroUsuarioId))
            q = q.Where(h => h.UsuarioId == filtroUsuarioId);
        horarios = await q.OrderBy(h => h.Usuario!.NombreCompleto).ThenBy(h => h.DiaSemana).ThenBy(h => h.HoraEntrada).ToListAsync();
        var ids = horarios.Select(h => h.UsuarioId).Distinct().ToList();
        trabConHorario = operariosDisponibles.Where(u => ids.Contains(u.Id)).ToList();
    }

    // --- Helpers ---
    private List<HorarioAsignado> TurnosDia(string uid, DiaSemana d) => horarios.Where(h => h.UsuarioId == uid && h.DiaSemana == d).ToList();
    private double HorasSemana(string uid) => horarios.Where(h => h.UsuarioId == uid).Sum(h => h.HorasPrevistas);
    private bool EsHoy(DiaSemana d) => d == (DateTime.Now.DayOfWeek switch {
        DayOfWeek.Monday => DiaSemana.Lunes, DayOfWeek.Tuesday => DiaSemana.Martes,
        DayOfWeek.Wednesday => DiaSemana.Miercoles, DayOfWeek.Thursday => DiaSemana.Jueves,
        DayOfWeek.Friday => DiaSemana.Viernes, DayOfWeek.Saturday => DiaSemana.Sabado,
        DayOfWeek.Sunday => DiaSemana.Domingo, _ => DiaSemana.Lunes });
    private string DiaCorto(DiaSemana d) => d switch {
        DiaSemana.Lunes => "LUN", DiaSemana.Martes => "MAR", DiaSemana.Miercoles => "MIÉ",
        DiaSemana.Jueves => "JUE", DiaSemana.Viernes => "VIE", DiaSemana.Sabado => "SÁB",
        DiaSemana.Domingo => "DOM", _ => d.ToString() };
    private string TurnoClass(TipoTurno t) => t switch {
        TipoTurno.Mañana => "t-man", TipoTurno.Tarde => "t-tar",
        TipoTurno.Noche => "t-noc", TipoTurno.Partido => "t-par", _ => "" };
    private string TurnoIcon(TipoTurno t) => t switch {
        TipoTurno.Mañana => "☀️", TipoTurno.Tarde => "🌅",
        TipoTurno.Noche => "🌙", TipoTurno.Partido => "📐", _ => "" };
    private string Iniciales(string n) { var p = n.Split(' ', StringSplitOptions.RemoveEmptyEntries); return p.Length >= 2 ? $"{p[0][0]}{p[1][0]}" : (p.Length > 0 ? p[0][0].ToString() : "?"); }
}
