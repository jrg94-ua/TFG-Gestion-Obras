@page "/login"
@using Microsoft.AspNetCore.Identity
@using GestionObras.Core.Entities
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject SignInManager<UsuarioObra> SignInManager
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Iniciar Sesión - Gestión de Obras</PageTitle>

<div class="login-page">
    <div class="login-wrapper">
        <!-- Panel izquierdo: Formulario -->
        <div class="login-form-panel">
            <div class="login-card">
                <div class="login-header">
                    <h2>🏗️ Gestión de Obras</h2>
                    <p>Inicia sesión para continuar</p>
                </div>

                <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin" FormName="loginForm">
                    <DataAnnotationsValidator />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    <div class="form-group mb-3">
                        <label for="email" class="form-label fw-semibold">Correo Electrónico</label>
                        <InputText id="email" class="form-control form-control-lg" @bind-Value="loginModel.Email" placeholder="usuario@ejemplo.com" />
                        <ValidationMessage For="@(() => loginModel.Email)" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="password" class="form-label fw-semibold">Contraseña</label>
                        <InputText id="password" type="password" class="form-control form-control-lg" @bind-Value="loginModel.Password" placeholder="••••••••" />
                        <ValidationMessage For="@(() => loginModel.Password)" />
                    </div>

                    <div class="form-group form-check mb-3">
                        <InputCheckbox id="rememberMe" class="form-check-input" @bind-Value="loginModel.RememberMe" />
                        <label class="form-check-label" for="rememberMe">Recordarme</label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <span> Iniciando sesión...</span>
                        }
                        else
                        {
                            <span>🔑 Iniciar Sesión</span>
                        }
                    </button>
                </EditForm>
            </div>
        </div>

        <!-- Panel derecho: Usuarios demo -->
        <div class="login-demo-panel">
            <h3 class="text-center mb-1" style="color: #2c3e50;">🧪 Acceso Rápido — Demo</h3>
            <p class="text-center text-muted mb-3" style="font-size: 0.85rem;">Haz clic en una tarjeta para rellenar el formulario</p>

            <div class="demo-users-grid">
                <!-- Administrador -->
                <div class="demo-user-card demo-admin" onclick="fillLogin('admin@gestionobras.com','Admin123!')">
                    <div class="demo-icon">👑</div>
                    <div class="demo-info">
                        <span class="demo-role">Administrador</span>
                        <span class="demo-name">Dirección General</span>
                        <span class="demo-email">admin@gestionobras.com</span>
                        <span class="demo-pass">Admin123!</span>
                    </div>
                </div>

                <!-- Jefe de Obra -->
                <div class="demo-user-card demo-jefe" onclick="fillLogin('jefe.norte@gestionobras.com','Demo123!')">
                    <div class="demo-icon">👷</div>
                    <div class="demo-info">
                        <span class="demo-role">Jefe de Obra</span>
                        <span class="demo-name">Álvaro Molina Serrano</span>
                        <span class="demo-email">jefe.norte@gestionobras.com</span>
                        <span class="demo-pass">Demo123!</span>
                    </div>
                </div>

                <!-- Oficina Técnica -->
                <div class="demo-user-card demo-oficina" onclick="fillLogin('oficina.senior@gestionobras.com','Demo123!')">
                    <div class="demo-icon">📐</div>
                    <div class="demo-info">
                        <span class="demo-role">Oficina Técnica</span>
                        <span class="demo-name">Lucía Sanchis Ferrer</span>
                        <span class="demo-email">oficina.senior@gestionobras.com</span>
                        <span class="demo-pass">Demo123!</span>
                    </div>
                </div>

                <!-- Recursos Humanos -->
                <div class="demo-user-card demo-rrhh" onclick="fillLogin('rrhh@gestionobras.com','Demo123!')">
                    <div class="demo-icon">🧑‍💼</div>
                    <div class="demo-info">
                        <span class="demo-role">Recursos Humanos</span>
                        <span class="demo-name">Elena Martínez García</span>
                        <span class="demo-email">rrhh@gestionobras.com</span>
                        <span class="demo-pass">Demo123!</span>
                    </div>
                </div>

                <!-- Operario de Obra -->
                <div class="demo-user-card demo-operario" onclick="fillLogin('obra.01@gestionobras.com','Demo123!')">
                    <div class="demo-icon">🔧</div>
                    <div class="demo-info">
                        <span class="demo-role">Operario de Obra</span>
                        <span class="demo-name">Iván Quintana Beltrán</span>
                        <span class="demo-email">obra.01@gestionobras.com</span>
                        <span class="demo-pass">Demo123!</span>
                    </div>
                </div>

                <!-- Operario Oficina Técnica -->
                <div class="demo-user-card demo-operariot" onclick="fillLogin('ot.01@gestionobras.com','Demo123!')">
                    <div class="demo-icon">📋</div>
                    <div class="demo-info">
                        <span class="demo-role">Operario Oficina Téc.</span>
                        <span class="demo-name">Paula Cuesta León</span>
