        </div>
    </div>
</div>

<script>
    function fillLogin(email, pass) {
        var emailInput = document.getElementById('email');
        var passInput = document.getElementById('password');
        if (emailInput) {
            // Set native value setter to trigger Blazor binding
            var nativeEmailSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
            nativeEmailSetter.call(emailInput, email);
            emailInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
        if (passInput) {
            var nativePassSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
            nativePassSetter.call(passInput, pass);
            passInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
        // Visual feedback
        var cards = document.querySelectorAll('.demo-user-card');
        cards.forEach(function(c) { c.classList.remove('selected'); });
        event.currentTarget.classList.add('selected');
    }
</script>

<style>
    .login-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .login-wrapper {
        display: flex;
        gap: 2rem;
        max-width: 1100px;
        width: 100%;
        align-items: stretch;
    }

    /* Panel formulario */
    .login-form-panel {
        flex: 0 0 380px;
        display: flex;
        align-items: center;
    }

    .login-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        width: 100%;
    }

    .login-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .login-header h2 {
        font-size: 1.6rem;
        color: #2c3e50;
        margin-bottom: 0.25rem;
    }

    .login-header p {
        color: #6c757d;
        font-size: 0.9rem;
    }

    /* Panel demo */
    .login-demo-panel {
        flex: 1;
        background: rgba(255,255,255,0.95);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    .demo-users-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .demo-user-card {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #fff;
    }

    .demo-user-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }

    .demo-user-card.selected {
        border-color: #0d6efd;
        box-shadow: 0 0 0 3px rgba(13,110,253,0.25);
        background: #f0f6ff;
    }

    .demo-icon {
        font-size: 2rem;
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
    }

    .demo-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
        gap: 1px;
    }

    .demo-role {
        font-weight: 700;
        font-size: 0.85rem;
        color: #2c3e50;
    }

    .demo-name {
        font-size: 0.75rem;
        color: #6c757d;
    }

    .demo-email {
        font-size: 0.7rem;
        color: #0d6efd;
        font-family: monospace;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .demo-pass {
        font-size: 0.7rem;
        color: #198754;
        font-family: monospace;
    }

    /* Colores por rol */
    .demo-admin { border-left: 4px solid #6f42c1; }
    .demo-admin .demo-icon { background: #f3efff; }
    .demo-admin .demo-role { color: #6f42c1; }

    .demo-jefe { border-left: 4px solid #fd7e14; }
    .demo-jefe .demo-icon { background: #fff5ed; }
    .demo-jefe .demo-role { color: #fd7e14; }

    .demo-oficina { border-left: 4px solid #0dcaf0; }
    .demo-oficina .demo-icon { background: #edfbff; }
    .demo-oficina .demo-role { color: #0ba5c7; }

    .demo-rrhh { border-left: 4px solid #20c997; }
    .demo-rrhh .demo-icon { background: #edfff8; }
    .demo-rrhh .demo-role { color: #198754; }

    .demo-operario { border-left: 4px solid #ffc107; }
    .demo-operario .demo-icon { background: #fffced; }
    .demo-operario .demo-role { color: #b58a00; }

    .demo-operariot { border-left: 4px solid #6c757d; }
    .demo-operariot .demo-icon { background: #f5f5f5; }
    .demo-operariot .demo-role { color: #6c757d; }

    /* Responsive */
    @@media (max-width: 900px) {
        .login-wrapper {
            flex-direction: column;
        }
        .login-form-panel {
            flex: unset;
        }
        .demo-users-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [SupplyParameterFromForm]
    private LoginModel loginModel { get; set; } = default!;
    
    private string? errorMessage;
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        loginModel ??= new();
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await SignInManager.PasswordSignInAsync(
                loginModel.Email,
                loginModel.Password,
                loginModel.RememberMe,
                lockoutOnFailure: false
            );

            if (result.Succeeded)
            {
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }
            else if (result.IsLockedOut)
            {
                errorMessage = "Tu cuenta está bloqueada. Contacta al administrador.";
            }
            else if (result.IsNotAllowed)
            {
                errorMessage = "Debes confirmar tu correo electrónico antes de iniciar sesión.";
            }
            else
            {
                errorMessage = "Correo o contraseña incorrectos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al iniciar sesión: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "El correo electrónico es obligatorio")]
        [EmailAddress(ErrorMessage = "El formato del correo no es válido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
